statement ok
CREATE TABLE mv_base_t (id INT, val VARCHAR, amount INT)

statement ok
CREATE TABLE mv_base_t2 (id INT)

statement ok
INSERT INTO mv_base_t VALUES (1, 'a', 10), (2, 'b', 20), (3, 'a', 30), (4, 'b', 40)

# CREATE MATERIALIZED VIEW populates the backing Fuse table.
statement ok
CREATE MATERIALIZED VIEW test_mv AS SELECT id, val, amount FROM mv_base_t WHERE id <= 2

query ITI
SELECT * FROM test_mv ORDER BY id
----
1 a 10
2 b 20

# DESC sees the materialized view schema.
query TTTTT
DESC test_mv
----
id INT YES NULL (empty)
val VARCHAR YES NULL (empty)
amount INT YES NULL (empty)

# SHOW CREATE MATERIALIZED VIEW
query TT
SHOW CREATE MATERIALIZED VIEW test_mv
----
test_mv CREATE MATERIALIZED VIEW `default`.`test_mv` AS SELECT id, val, amount FROM mv_base_t WHERE id <= 2

# SHOW CREATE TABLE on MV outputs MV DDL.
query TT
SHOW CREATE TABLE test_mv
----
test_mv CREATE MATERIALIZED VIEW `default`.`test_mv` AS SELECT id, val, amount FROM mv_base_t WHERE id <= 2

# REFRESH is intentionally not implemented in phase 1.
statement error 1002
REFRESH MATERIALIZED VIEW test_mv

# SHOW CREATE MATERIALIZED VIEW rejects base tables.
statement error
SHOW CREATE MATERIALIZED VIEW mv_base_t

# SHOW MATERIALIZED VIEWS surfaces the MV object.
query T
SELECT name FROM system.tables WHERE database = 'default' AND table_type = 'MATERIALIZED VIEW' ORDER BY name
----
test_mv

query I
SELECT count(*) FROM system.tables WHERE database = 'default' AND name = 'test_mv' AND table_type = 'BASE TABLE'
----
0

query TT
SELECT engine, table_type FROM system.tables WHERE database = 'default' AND name = 'test_mv'
----
MATERIALIZED_VIEW MATERIALIZED VIEW

statement ok
SHOW MATERIALIZED VIEWS FROM default.default LIKE 'test_mv'

# IF NOT EXISTS
statement ok
CREATE MATERIALIZED VIEW IF NOT EXISTS test_mv AS SELECT id FROM mv_base_t

# Error: already exists
statement error 2330
CREATE MATERIALIZED VIEW test_mv AS SELECT id FROM mv_base_t

# CREATE OR REPLACE MATERIALIZED VIEW
statement ok
CREATE OR REPLACE MATERIALIZED VIEW test_mv AS SELECT val, COUNT(*) AS cnt FROM mv_base_t GROUP BY val

query TI
SELECT * FROM test_mv ORDER BY val
----
a 2
b 2

# CREATE OR REPLACE TABLE cannot replace an MV.
statement error 1302
CREATE OR REPLACE TABLE test_mv (x INT)

# CREATE OR REPLACE MATERIALIZED VIEW cannot replace a regular table.
statement error 1302
CREATE OR REPLACE MATERIALIZED VIEW mv_base_t AS SELECT * FROM mv_base_t

# CREATE OR REPLACE MATERIALIZED VIEW cannot depend on the old MV object.
statement error 1029
CREATE OR REPLACE MATERIALIZED VIEW test_mv AS SELECT * FROM test_mv

# Replace back to a stable definition for guard/drop tests.
statement ok
CREATE OR REPLACE MATERIALIZED VIEW test_mv AS SELECT id, val, amount FROM mv_base_t WHERE id <= 2

# Protected options: user cannot set MV options via CREATE TABLE.
statement error 1301
CREATE TABLE fake_mv (x INT) materialized_view = 'true'

# The MV engine cannot be used to bypass CREATE MATERIALIZED VIEW metadata creation.
statement error 1005
CREATE TABLE fake_mv_engine (x INT) ENGINE = MATERIALIZED_VIEW

# Protected options: user cannot set MV options via ALTER TABLE.
statement error 1302
ALTER TABLE test_mv SET OPTIONS (materialized_view_query = 'SELECT 1')

statement error
ALTER TABLE test_mv SET OPTIONS (block_per_segment = 10)

statement error
ALTER TABLE test_mv UNSET OPTIONS (block_per_segment)

statement error
ALTER VIEW test_mv AS SELECT 1

statement error
CREATE OR REPLACE VIEW test_mv AS SELECT id FROM mv_base_t

statement error
ALTER TABLE test_mv RENAME TO test_mv_renamed

statement error
ALTER TABLE test_mv SWAP WITH mv_base_t

# All ALTER TABLE operations are blocked on materialized views.
statement error 1302
ALTER TABLE test_mv COMMENT = 'changed'

statement error 1302
ALTER TABLE test_mv CONNECTION = (CONNECTION_NAME = 'missing')

statement error 1302
ALTER TABLE test_mv ADD COLUMN new_col INT

statement error 1302
ALTER TABLE test_mv DROP COLUMN val

statement error 1302
ALTER TABLE test_mv RENAME COLUMN val TO value

statement error 1302
ALTER TABLE test_mv MODIFY COLUMN amount BIGINT

statement error 1302
ALTER TABLE test_mv ADD CONSTRAINT positive_id CHECK (id > 0)

statement error 1302
ALTER TABLE test_mv DROP CONSTRAINT positive_id

statement error 1302
ALTER TABLE test_mv RECLUSTER

statement error 1302
ALTER TABLE test_mv FLASHBACK TO (SNAPSHOT => '00000000-0000-0000-0000-000000000000')

statement error 1302
ALTER TABLE test_mv REFRESH CACHE

statement error 1302
ALTER TABLE test_mv CREATE TAG mv_snapshot

statement error 1302
ALTER TABLE test_mv DROP TAG mv_snapshot

statement error 1302
ALTER TABLE test_mv SET TAG missing_tag = 'value'

statement error 1302
ALTER TABLE test_mv UNSET TAG missing_tag

# TRUNCATE is blocked on materialized views.
statement error 1302
TRUNCATE TABLE test_mv

# User writes are blocked on materialized views.
statement error 1302
INSERT INTO test_mv VALUES (5, 'c', 50)

statement error 1302
UPDATE test_mv SET val = 'changed' WHERE id = 1

statement error 1302
DELETE FROM test_mv WHERE id = 1

statement error 1302
MERGE INTO test_mv AS target
USING (SELECT 1 AS id, 'changed' AS val, 100 AS amount) AS source
ON target.id = source.id
WHEN MATCHED THEN UPDATE SET target.val = source.val
WHEN NOT MATCHED THEN INSERT (id, val, amount) VALUES (source.id, source.val, source.amount)

statement error 1302
REPLACE INTO test_mv ON CONFLICT(id) VALUES (1, 'changed', 100)

statement error 1302
INSERT ALL
    INTO test_mv VALUES (id, val, amount)
SELECT 5 AS id, 'c' AS val, 50 AS amount

