USE default

# CTE in materialized view: top-level WITH
statement ok
CREATE MATERIALIZED VIEW test_mv_cte AS WITH c AS (SELECT val, SUM(amount) AS total FROM mv_base_t GROUP BY val) SELECT * FROM c

query TI
SELECT * FROM test_mv_cte ORDER BY val
----
a 40
b 60

query TT
SHOW CREATE MATERIALIZED VIEW test_mv_cte
----
test_mv_cte CREATE MATERIALIZED VIEW `default`.`test_mv_cte` AS WITH c AS (SELECT val, SUM(amount) AS total FROM mv_base_t GROUP BY val) SELECT * FROM c

# CTE in materialized view: nested CTE inside subquery
statement ok
CREATE MATERIALIZED VIEW test_mv_nested_cte AS SELECT * FROM (WITH c AS (SELECT val, SUM(amount) AS total FROM mv_base_t GROUP BY val) SELECT * FROM c) s

query TI
SELECT * FROM test_mv_nested_cte ORDER BY val
----
a 40
b 60

query TT
SHOW CREATE MATERIALIZED VIEW test_mv_nested_cte
----
test_mv_nested_cte CREATE MATERIALIZED VIEW `default`.`test_mv_nested_cte` AS SELECT * FROM (WITH c AS (SELECT val, SUM(amount) AS total FROM mv_base_t GROUP BY val) SELECT * FROM c) AS s

# Materialized CTEs are not supported in MV definitions.
statement error 1005
CREATE MATERIALIZED VIEW test_mv_mat_cte AS WITH c AS MATERIALIZED (SELECT val FROM mv_base_t) SELECT * FROM c

statement error 1005
CREATE MATERIALIZED VIEW test_mv_nested_mat_cte AS SELECT * FROM (WITH c AS MATERIALIZED (SELECT val FROM mv_base_t) SELECT * FROM c) s

# PIVOT forms that execute subqueries during planning are not supported in MV definitions.
statement error 1005
CREATE MATERIALIZED VIEW test_mv_pivot_any AS SELECT * FROM mv_base_t PIVOT(SUM(amount) FOR val IN (ANY))

statement error 1005
CREATE MATERIALIZED VIEW test_mv_pivot_subquery AS SELECT * FROM mv_base_t PIVOT(SUM(amount) FOR val IN (SELECT DISTINCT val FROM mv_base_t))

